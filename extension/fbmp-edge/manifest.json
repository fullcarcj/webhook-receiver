{
  "manifest_version": 3,
  "name": "fbmp_edge — Marketplace Bridge",
  "version": "1.0.0",
  "description": "Puente privado entre Facebook Marketplace Personal y el ERP (inbound scraper + outbound relay).",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/messages/*",
        "https://www.facebook.com/marketplace/inbox/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "fbmp_edge"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
