# Copia a: oauth-credentials.ps1 (no lo subas a git)
#
# En Mercado Libre "Application ID" = Client ID
# "Secret Key" = Client Secret

# --- OAuth (llamadas API con refresh) ---
$env:OAUTH_CLIENT_ID = "TU_APPLICATION_ID"
$env:OAUTH_CLIENT_SECRET = "TU_SECRET_KEY"
$env:OAUTH_REFRESH_TOKEN = "TU_REFRESH_TOKEN"

# Opcional: archivo donde se guarda el refresh si Mercado Libre lo rota
# $env:OAUTH_TOKEN_FILE = "$PSScriptRoot\ml-token.json"

# --- Solo la PRIMERA vez: tienes "authorization code" en lugar de refresh ---
# 1) En la app ML, Redirect URI debe coincidir con esta URL (exacto):
#    $env:OAUTH_REDIRECT_URI = "https://solomotor.loclx.io/reg.php"
# 2) Pon el code que te devolvió el navegador:
#    $env:OAUTH_AUTH_CODE = "TG-..."
# 3) Ejecuta: node exchange-auth-code.js
# 4) Copia el refresh_token del JSON a OAUTH_REFRESH_TOKEN y borra OAUTH_AUTH_CODE

# --- Varias cuentas de Mercado Libre (misma app, un vendedor por fila) ---
# Cada vendedor autoriza la app y obtienes su user_id + refresh_token.
# Guarda cada uno en la base (con el servidor parado o con ADMIN_SECRET):
#   $env:ML_USER_ID = "1234567890"
#   $env:OAUTH_REFRESH_TOKEN = "TG-..."
#   node registrar-cuenta-ml.js
# O con intercambio de codigo: ML_SAVE_ACCOUNT=1 node exchange-auth-code.js
# En el servidor:
#   $env:ADMIN_SECRET = "una-clave-larga"
# Lista en el navegador (misma clave en la URL):
#   http://localhost:3000/cuentas?k=una-clave-larga
# JSON: .../cuentas?k=...&format=json
# Luego POST http://localhost:3000/admin/ml-accounts
#   cabecera X-Admin-Secret, JSON: {"ml_user_id":123,"refresh_token":"TG-..."}
# El webhook trae `user_id`: el codigo usa ese id para llamar a la API con la cuenta correcta.
# Opcional: $env:ML_WEBHOOK_FETCH_ORDER = "1"  (descarga el recurso del pedido con la cuenta de user_id)
#
# Renovacion automatica del access_token (~21600 s) para TODAS las cuentas en ml_accounts:
# - Al arrancar node server.js se pide token a cada una (escalonado, ML_ACCOUNT_STAGGER_MS por defecto 500).
# - Tras cada renovacion se programa el siguiente refresh antes de que venza (OAUTH_EXPIRY_MARGIN_SEC, default 120).
# - Desactivar temporizadores: $env:OAUTH_PROACTIVE_REFRESH = "0"

# --- Reenviar webhooks de este servidor a tu PHP ---
# Si este Node recibe el webhook y quieres reenviar el JSON a reg.php:
# $env:POST_URL_1 = "https://solomotor.loclx.io/reg.php"
